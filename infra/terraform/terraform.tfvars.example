region             = "ap-south-1"
platform           = "platform"
environment        = "service-dev"
instance_type      = "t3.micro"
docker_image       = "ghcr.io/bh-an/ec2-go-service:latest"
exposure_kind      = "module-public"
enable_nat_gateways = false
# key_pair_name    = "my-key-pair"

